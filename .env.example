# NordVPN WireGuard (NordLynx) private key (REQUIRED)
# Fetch with your NordVPN access token (from
# https://my.nordaccount.com/dashboard/nordvpn/manual-configuration/):
#   TOKEN=your_token
#   curl -s -u "token:$TOKEN" https://api.nordvpn.com/v1/users/services/credentials \
#     | jq -r .nordlynx_private_key
WIREGUARD_PRIVATE_KEY=your_nordlynx_private_key

# Timezone (REQUIRED)
TZ=America/New_York

# Optional: Specific NordVPN server (leave blank for auto-selection)
# SERVER_HOSTNAMES=us1234.nordvpn.com

# Optional: VPN server countries (defaults to United States)
# SERVER_COUNTRIES=United States,Canada

# Immich Configuration
IMMICH_VERSION=release
IMMICH_DB_USERNAME=immich
IMMICH_DB_PASSWORD=change_me_to_secure_password
IMMICH_DB_NAME=immich